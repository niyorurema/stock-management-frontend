{
  "extends": ["react-app"],
  "rules": {
    "no-unused-vars": ["warn", { 
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_"
    }],
    "react-hooks/exhaustive-deps": "warn",
    "eqeqeq": ["warn", "smart"],
    "no-useless-escape": "warn",
    "jsx-a11y/anchor-is-valid": "warn",
    "no-template-curly-in-string": "warn"
  }
}